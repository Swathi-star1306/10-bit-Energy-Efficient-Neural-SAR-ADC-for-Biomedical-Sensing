#=========================================================
# TCL SYNTHESIS SCRIPT
# PROJECT : 10-BIT ENERGY-EFFICIENT SAR ADC
# DESIGN  : neural_sar_adc_top
# FLOW    : NC Launch -> Genus
# TARGET  : 55nm / 28nm CMOS
#=========================================================

#---------------------------------------------------------
# SET LIBRARY PATH
#---------------------------------------------------------

set_db init_lib_search_path /cadence/install/FOUNDRY-01/digital/55nm/dig/lib

#---------------------------------------------------------
# READ LIBRARY + RTL
#---------------------------------------------------------

read_libs slow.lib

read_hdl neural_sar_adc_top.v

elaborate neural_sar_adc_top

#---------------------------------------------------------
# READ CONSTRAINTS
#---------------------------------------------------------

read_sdc ./constraints.sdc

#---------------------------------------------------------
# DESIGN CHECK
#---------------------------------------------------------

check_design

#---------------------------------------------------------
# SYNTHESIS
#---------------------------------------------------------

syn_gen

syn_map

syn_opt

#---------------------------------------------------------
# LOW POWER OPTIMIZATION
#---------------------------------------------------------

set_db lp_insert_clock_gating true

set_db leakage_power_effort high

set_db dynamic_power_effort high

#---------------------------------------------------------
# TIMING ANALYSIS
#---------------------------------------------------------

report_timing > timing.rpt

#---------------------------------------------------------
# AREA REPORT
#---------------------------------------------------------

report_area > area.rpt

#---------------------------------------------------------
# POWER REPORT
#---------------------------------------------------------

report_power > power.rpt

#---------------------------------------------------------
# QoR REPORT
#---------------------------------------------------------

report_qor > qor.rpt

#---------------------------------------------------------
# CELL UTILIZATION REPORT
#---------------------------------------------------------

report_gates > gates.rpt

#---------------------------------------------------------
# WRITE SYNTHESIZED NETLIST
#---------------------------------------------------------

write_hdl > neural_sar_adc_netlist.v

#---------------------------------------------------------
# WRITE SDC
#---------------------------------------------------------

write_sdc > neural_sar_adc_final.sdc

#---------------------------------------------------------
# END OF SCRIPT
#---------------------------------------------------------
